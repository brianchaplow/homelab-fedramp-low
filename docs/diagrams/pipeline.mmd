    classDef stage fill:#f3e5f5,stroke:#7b1fa2;
    classDef output fill:#e8f5e9,stroke:#388e3c;
    class WAZUH_API,WAZUH_IDX,OVERLAY source;
    class INGEST,PUSH,BUILD,RENDER,PUSH_REGSCALE,ING_INV,ING_VULN,PUSH_DD,BUILD_COMP,BUILD_POAM,BUILD_SSP,REN_IIW,REN_POAM,PUSH_RS stage;
    class OSCAL_COMP,OSCAL_POAM,OSCAL_SSP,IIW_XLSX,POAM_XLSX output;
